{
  "appName": "A11 Local",
  "shellWindow": {
    "label": "main",
    "title": "A11 Local",
    "width": 560,
    "height": 760,
    "minWidth": 520,
    "minHeight": 720
  },
  "chatWindow": {
    "label": "a11-chat",
    "title": "A11",
    "width": 1480,
    "height": 980,
    "minWidth": 980,
    "minHeight": 720
  },
  "runtime": {
    "host": "127.0.0.1",
    "uiUrl": "http://127.0.0.1:3000",
    "servicePorts": [
      {
        "key": "backend",
        "label": "Backend",
        "port": 3000,
        "required": true,
        "enableEnvKey": "A11_ENABLE_BACKEND"
      },
      {
        "key": "tts",
        "label": "TTS",
        "port": 5002,
        "required": true,
        "enableEnvKey": "A11_ENABLE_TTS"
      },
      {
        "key": "llm",
        "label": "LLM",
        "port": 8080,
        "required": true,
        "enableEnvKey": "A11_ENABLE_LLM"
      },
      {
        "key": "qflush",
        "label": "Qflush",
        "port": 43421,
        "required": false,
        "enableEnvKey": "A11_ENABLE_QFLUSH"
      }
    ]
  },
  "installerLite": {
    "enabled": true,
    "defaultModelId": "llama32-3b-q4km",
    "defaultModelFileName": "Llama-3.2-3B-Instruct-Q4_K_M.gguf",
    "defaultModelUrl": "https://huggingface.co/bartowski/Llama-3.2-3B-Instruct-GGUF/resolve/main/Llama-3.2-3B-Instruct-Q4_K_M.gguf?download=true",
    "downloadTimeoutSec": 14400
  },
  "modelCatalog": [
    {
      "id": "llama32-3b-q4km",
      "label": "Llama 3.2 3B Instruct",
      "fileName": "Llama-3.2-3B-Instruct-Q4_K_M.gguf",
      "downloadUrl": "https://huggingface.co/bartowski/Llama-3.2-3B-Instruct-GGUF/resolve/main/Llama-3.2-3B-Instruct-Q4_K_M.gguf?download=true",
      "sizeHint": "~2.0 Go",
      "description": "Profil recommande pour A11 local: bon equilibre entre qualite, taille et vitesse.",
      "recommended": true
    },
    {
      "id": "llama32-1b-q4km",
      "label": "Llama 3.2 1B Instruct",
      "fileName": "Llama-3.2-1B-Instruct-Q4_K_M.gguf",
      "downloadUrl": "https://huggingface.co/bartowski/Llama-3.2-1B-Instruct-GGUF/resolve/main/Llama-3.2-1B-Instruct-Q4_K_M.gguf?download=true",
      "sizeHint": "~0.8 Go",
      "description": "Option legere pour petites machines ou demarrage rapide.",
      "recommended": false
    },
    {
      "id": "qwen25-3b-q4km",
      "label": "Qwen 2.5 3B Instruct",
      "fileName": "qwen2.5-3b-instruct-q4_k_m.gguf",
      "downloadUrl": "https://huggingface.co/Qwen/Qwen2.5-3B-Instruct-GGUF/resolve/main/qwen2.5-3b-instruct-q4_k_m.gguf?download=true",
      "sizeHint": "~2.1 Go",
      "description": "Alternative solide en conversation et raisonnement general.",
      "recommended": false
    }
  ],
  "remoteProviders": [
    {
      "id": "openai",
      "label": "OpenAI",
      "baseUrl": "https://api.openai.com/v1",
      "defaultModel": "gpt-4o-mini",
      "description": "Connexion directe a OpenAI via une cle API."
    },
    {
      "id": "grok",
      "label": "xAI / Grok",
      "baseUrl": "https://api.x.ai/v1",
      "defaultModel": "",
      "description": "Endpoint compatible OpenAI. Entre le nom du modele xAI de ton compte."
    },
    {
      "id": "openrouter",
      "label": "OpenRouter",
      "baseUrl": "https://openrouter.ai/api/v1",
      "defaultModel": "openai/gpt-4o-mini",
      "description": "Routeur multi-modeles compatible OpenAI."
    },
    {
      "id": "custom",
      "label": "Custom OpenAI-compatible",
      "baseUrl": "",
      "defaultModel": "",
      "description": "Pour toute API compatible OpenAI ou Grok-like."
    }
  ],
  "paths": {
    "repoLauncherScript": "../launchers/a11-local.ps1",
    "repoLauncherConfig": "../launchers/config/a11-local.env",
    "repoLogsDir": "../launchers/runtime/logs",
    "packagedRoot": "a11-local",
    "packagedLauncherScript": "launcher/a11-local.ps1",
    "packagedLauncherConfig": "launcher/config/a11-local.env",
    "packagedLogsDir": "launcher/runtime/logs"
  }
}
