{
  "name": "a11-local-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "desktop:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-local-package.ps1",
