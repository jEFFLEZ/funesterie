  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
