# Example env vars for qflush/NPZ Daemon
NPZ_ADMIN_TOKEN=changeme
QFLUSH_TOKEN=changeme

# Redis URL (optional) - leave unset to force in-memory mode
# REDIS_URL=redis://127.0.0.1:6379
QFLUSH_DISABLE_REDIS=1

# Ports
QFLUSHD_PORT=43421
QFLUSH_SPYDER_ADMIN_PORT=4022

# Runtime mode
QFLUSH_MODE=daemon

# Protect orchestration routes when a token is configured
QFLUSH_REQUIRE_AUTH=1
# Optional compatibility allowlist for POST /run and direct chat flow exposure
# QFLUSH_RUN_ALLOWLIST=a11.chat.v1,a11.memory.summary.v1
# QFLUSH_ALLOWED_FLOWS=a11.chat.v1,a11.memory.summary.v1

# Preferred flow exposure split
# QFLUSH_PUBLIC_FLOWS=a11.chat.v1,a11.memory.summary.v1
# QFLUSH_ADMIN_FLOWS=web_fetch,fs.search
# QFLUSH_INTERNAL_FLOWS=

# Copilot / telemetry (disabled by default)
QFLUSH_DISABLE_COPILOT=1
QFLUSH_TELEMETRY=0
# QFLUSH_DEBUG=0
# QFLUSH_DEBUG_NPZ=0

# Optional chat upstream used by flow a11.chat.v1
# QFLUSH_CHAT_UPSTREAM=https://your-llm-or-a11-upstream.example.com
# QFLUSH_CHAT_MODEL=gpt-4o-mini
# LOCAL_LLM_URL=https://your-ngrok-or-llama-cpp.example.com
# LLAMA_BASE=https://your-openai-compatible-llm.example.com/v1
# LLM_URL=https://your-openai-compatible-llm.example.com/v1
# OLLAMA_URL=http://127.0.0.1:11434
# QFLUSH_LOCAL_MODEL_HINTS=llama,mistral,qwen,gemma,phi,deepseek
# QFLUSH_CHAT_TEMPERATURE=0.7
# QFLUSH_CHAT_N_PREDICT=512

# Optional upstream health probes for /health and /status
# QFLUSH_HEALTH_PROBE_UPSTREAMS=1
# QFLUSH_HEALTH_PROBE_TTL_MS=15000
# QFLUSH_HEALTH_PROBE_TIMEOUT_MS=1200
# QFLUSH_PROBE_OPENAI=0
# LOCAL_LLM_HEALTH_URL=https://your-ngrok-or-llama-cpp.example.com/health
# QFLUSH_CHAT_UPSTREAM_HEALTH_URL=https://your-upstream.example.com/health
# OPENAI_COMPATIBLE_HEALTH_URL=https://your-openai-compatible-llm.example.com/health
# LLAMA_BASE_HEALTH_URL=https://your-openai-compatible-llm.example.com/health
# LLM_URL_HEALTH_URL=https://your-openai-compatible-llm.example.com/health
# A11_SERVER_HEALTH_URL=https://your-a11-or-upstream.example.com/health
# OPENAI_HEALTH_URL=https://api.openai.com/v1/models
# OLLAMA_HEALTH_URL=http://127.0.0.1:11434/api/tags

# Do NOT set these here. Configure securely via secrets if needed:
# COPILOT_HMAC_SECRET=
# COPILOT_WEBHOOK_URL=
# COPILOT_BRIDGE_URL=

# Test token used by test helper (set in repo secrets)
QFLUSH_TEST_TOKEN=
