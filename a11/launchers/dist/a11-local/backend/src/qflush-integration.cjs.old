/**
 * Process Supervision Integration for A11
 * Uses A11Supervisor for reliable process management
 */

const path = require('node:path');
const fs = require('node:fs');
const { A11Supervisor } = require('./a11-supervisor.cjs');

// Always available since we have our own implementation
const qflushAvailable = true;

/**
 * Initialize supervisor
 * @param {Object} options - Configuration options
 * @returns {A11Supervisor} Supervisor instance
 */
function initQFlush(options = {}) {
  try {
    const config = {
      maxRestarts: options.maxRestarts || 3,
      restartDelay: options.restartDelay || 2000,
      logDir: options.logDir || path.resolve(__dirname, '../../logs/supervisor'),
      ...options
    };

    console.log('[Supervisor] Initializing A11 supervisor...');
    const supervisor = new A11Supervisor(config);
    return supervisor;
  } catch (e) {
    console.error('[Supervisor] Initialization failed:', e.message);
    return null;
  }
}

/**
 * Register a process for supervision
 * @param {A11Supervisor} supervisor - Supervisor instance
 * @param {Object} processConfig - Process configuration
 * @returns {boolean} Success status
 */
function registerProcess(supervisor, processConfig) {
  if (!supervisor) {
    console.warn('[Supervisor] Cannot register process: supervisor not initialized');
    return false;
  }

  try {
    supervisor.register(processConfig);
    return true;
  } catch (e) {
    console.error('[Supervisor] Process registration failed:', e.message);
    return false;
  }
}

/**
 * Start supervised process
 * @param {A11Supervisor} supervisor - Supervisor instance
 * @param {string} processName - Name of the process to start
 * @returns {boolean} Success status
 */
function startProcess(supervisor, processName) {
  if (!supervisor) {
    console.warn('[Supervisor] Cannot start process: supervisor not initialized');
    return false;
  }

  try {
    supervisor.start(processName);
    return true;
  } catch (e) {
    console.error('[Supervisor] Failed to start process:', e.message);
    return false;
  }
}

/**
 * Stop supervised process
 * @param {A11Supervisor} supervisor - Supervisor instance
 * @param {string} processName - Name of the process to stop
 * @returns {boolean} Success status
 */
function stopProcess(supervisor, processName) {
  if (!supervisor) {
    console.warn('[Supervisor] Cannot stop process: supervisor not initialized');
    return false;
  }

  try {
    supervisor.stop(processName);
    return true;
  } catch (e) {
    console.error('[Supervisor] Failed to stop process:', e.message);
    return false;
  }
}

/**
 * Restart supervised process
 * @param {A11Supervisor} supervisor - Supervisor instance
 * @param {string} processName - Name of the process to restart
 * @returns {boolean} Success status
 */
function restartProcess(supervisor, processName) {
  if (!supervisor) {
    console.warn('[Supervisor] Cannot restart process: supervisor not initialized');
    return false;
  }

  try {
    supervisor.restart(processName);
    return true;
  } catch (e) {
    console.error('[Supervisor] Failed to restart process:', e.message);
    return false;
  }
}

/**
 * Get status of supervised processes
 * @param {A11Supervisor} supervisor - Supervisor instance
 * @returns {Object} Status information
 */
function getStatus(supervisor) {
  if (!supervisor) {
    return { available: false, error: 'Supervisor not initialized', processes: {} };
  }

  try {
    const status = supervisor.getStatus();
    return { available: true, ...status };
  } catch (e) {
    console.error('[Supervisor] Failed to get status:', e.message);
    return { available: true, error: e.message, processes: {} };
  }
}

/**
 * Setup supervisor for A11 services
 * @returns {A11Supervisor} Configured supervisor instance
 */
function setupA11Supervisor() {
  const supervisor = initQFlush({
    maxRestarts: 3,
    restartDelay: 3000,
    logDir: path.resolve(__dirname, '../../logs/supervisor')
  });

  if (!supervisor) {
    return null;
  }

  // Check if we should manage llama-server
  const useExternalLlama = process.env.LLAMA_BASE && process.env.LLAMA_BASE.trim();
  const useLlmRouter = process.env.LLM_ROUTER_URL && process.env.LLM_ROUTER_URL.trim();
  const manageLlamaServer = process.env.MANAGE_LLAMA_SERVER !== 'false';
  
  if (!useExternalLlama && !useLlmRouter && manageLlamaServer) {
    const llamaExe = findLlamaExe();
    const model = findModel();
    
    if (llamaExe && model) {
      console.log('[Supervisor] Registering llama-server for supervision');
      const mmproj = findMmproj();
      const args = [
        '-m', model,
        '--ctx-size', String(process.env.CTX_SIZE || 8192),
        '--batch-size', String(process.env.BATCH_SIZE || 4096),
        '--host', '127.0.0.1',
        '--port', '8000',
        '--parallel', String(process.env.PARALLEL || 8),
        '--temp', '0.7'
      ];
      
      if (mmproj) {
        console.log('[Supervisor] Adding multimodal support (mmproj)');
        args.push('--mmproj', mmproj);
      }
      
      registerProcess(supervisor, {
        name: 'llama-server',
        command: llamaExe,
        args,
        cwd: path.dirname(llamaExe),
        autoRestart: true
      });
    } else {
      if (!llamaExe) console.warn('[Supervisor] llama-server executable not found');
      if (!model) console.warn('[Supervisor] Model file not found');
    }
  } else {
    if (useExternalLlama) {
      console.log('[Supervisor] Using external LLAMA_BASE - not managing llama-server');
    }
    if (useLlmRouter) {
      console.log('[Supervisor] Using LLM Router - not managing llama-server');
    }
  }

  return supervisor;
}

// Helper functions
function findLlamaExe() {
  const BASE = path.resolve(__dirname, '../..');
  const LLAMA_DIR = path.join(BASE, 'llama.cpp');
  const guesses = [
    path.join(LLAMA_DIR, 'build', 'bin', 'Release', 'llama-server.exe'),
    path.join(LLAMA_DIR, 'build', 'bin', 'llama-server.exe')
  ];
  
  for (const g of guesses) {
    if (fs.existsSync(g)) {
      console.log('[Supervisor] Found llama-server at:', g);
      return g;
    }
  }
  
  return null;
}

function findModel() {
  const BASE = path.resolve(__dirname, '../..');
  const modelPath = process.env.DEFAULT_MODEL || process.env.LLAMA_MODEL;
  if (modelPath && fs.existsSync(modelPath)) {
    console.log('[Supervisor] Using model from env:', modelPath);
    return modelPath;
  }
  
  const guesses = [
    path.join(BASE, 'Models', 'keykey', 'Llama-3.2-3B-Instruct-Q4_K_M.gguf'),
    path.join(BASE, 'Models', 'llama-3.2-3b-instruct-q4_k_m.gguf'),
    path.join(BASE, 'llama.cpp', 'models', 'llama-3.2-3b-instruct-q4_k_m.gguf')
  ];
  
  for (const g of guesses) {
    if (fs.existsSync(g)) {
      console.log('[Supervisor] Found model at:', g);
      return g;
    }
  }
  
  return null;
}

function findMmproj() {
  const BASE = path.resolve(__dirname, '../..');
  const guesses = [
    path.join(BASE, 'Models', 'mmproj-llava-v1.5-7b-f16.gguf'),
    path.join(BASE, 'llama.cpp', 'models', 'mmproj-llava-v1.5-7b-f16.gguf')
  ];
  
  for (const g of guesses) {
    if (fs.existsSync(g)) return g;
  }
  
  return null;
}

module.exports = {
  qflushAvailable,
  initQFlush,
  registerProcess,
  startProcess,
  stopProcess,
  restartProcess,
  getStatus,
  setupA11Supervisor
};
