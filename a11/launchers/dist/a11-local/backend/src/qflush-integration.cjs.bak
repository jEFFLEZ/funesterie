/**
 * QFlush Integration Module for A11
 * Provides process supervision and management using QFlush
 */

const path = require('node:path');
const fs = require('node:fs');

let qflush = null;
let qflushAvailable = false;

// Try to load @funeste38/qflush
try {
  qflush = require('@funeste38/qflush');
  qflushAvailable = true;
  console.log('[QFLUSH] Successfully loaded @funeste38/qflush module');
} catch (e) {
  console.log('[QFLUSH] Module not available:', e.message);
}

/**
 * Initialize QFlush supervisor
 * @param {Object} options - Configuration options
 * @returns {Object} QFlush instance or null
 */
function initQFlush(options = {}) {
  if (!qflushAvailable) {
    console.warn('[QFLUSH] Cannot initialize: module not available');
    return null;
  }

  try {
    const config = {
      name: options.name || 'A11-Supervisor',
      logDir: options.logDir || path.resolve(__dirname, '../../logs/qflush'),
      maxRestarts: options.maxRestarts || 5,
      restartDelay: options.restartDelay || 2000,
      ...options
    };

    // Ensure log directory exists
    if (!fs.existsSync(config.logDir)) {
      fs.mkdirSync(config.logDir, { recursive: true });
    }

    console.log('[QFLUSH] Initializing with config:', config);
    const supervisor = qflush.createSupervisor(config);
    return supervisor;
  } catch (e) {
    console.error('[QFLUSH] Initialization failed:', e.message);
    return null;
  }
}

/**
 * Register a process for supervision
 * @param {Object} supervisor - QFlush supervisor instance
 * @param {Object} processConfig - Process configuration
 * @returns {boolean} Success status
 */
function registerProcess(supervisor, processConfig) {
  if (!supervisor) {
    console.warn('[QFLUSH] Cannot register process: supervisor not initialized');
    return false;
  }

  try {
    const config = {
      name: processConfig.name || 'unnamed-process',
      command: processConfig.command,
      args: processConfig.args || [],
      cwd: processConfig.cwd || process.cwd(),
      env: processConfig.env || {},
      autoRestart: processConfig.autoRestart !== false,
      ...processConfig
    };

    console.log('[QFLUSH] Registering process:', config.name);
    supervisor.register(config);
    return true;
  } catch (e) {
    console.error('[QFLUSH] Process registration failed:', e.message);
    return false;
  }
}

/**
 * Start supervised process
 * @param {Object} supervisor - QFlush supervisor instance
 * @param {string} processName - Name of the process to start
 * @returns {Promise<boolean>} Success status
 */
async function startProcess(supervisor, processName) {
  if (!supervisor) {
    console.warn('[QFLUSH] Cannot start process: supervisor not initialized');
    return false;
  }

  try {
    console.log('[QFLUSH] Starting process:', processName);
    await supervisor.start(processName);
    return true;
  } catch (e) {
    console.error('[QFLUSH] Failed to start process:', e.message);
    return false;
  }
}

/**
 * Stop supervised process
 * @param {Object} supervisor - QFlush supervisor instance
 * @param {string} processName - Name of the process to stop
 * @returns {Promise<boolean>} Success status
 */
async function stopProcess(supervisor, processName) {
  if (!supervisor) {
    console.warn('[QFLUSH] Cannot stop process: supervisor not initialized');
    return false;
  }

  try {
    console.log('[QFLUSH] Stopping process:', processName);
    await supervisor.stop(processName);
    return true;
  } catch (e) {
    console.error('[QFLUSH] Failed to stop process:', e.message);
    return false;
  }
}

/**
 * Get status of supervised processes
 * @param {Object} supervisor - QFlush supervisor instance
 * @returns {Object} Status information
 */
function getStatus(supervisor) {
  if (!supervisor) {
    return { available: false, processes: [] };
  }

  try {
    return supervisor.getStatus();
  } catch (e) {
    console.error('[QFLUSH] Failed to get status:', e.message);
    return { available: true, error: e.message, processes: [] };
  }
}

/**
 * Setup QFlush for A11 services
 * @returns {Object} Configured supervisor instance
 */
function setupA11Supervisor() {
  const supervisor = initQFlush({
    name: 'A11-Services',
    logDir: path.resolve(__dirname, '../../logs/qflush'),
    maxRestarts: 3,
    restartDelay: 3000
  });

  if (!supervisor) {
    return null;
  }

  // Register llama-server if not using external upstream
  const useExternalLlama = process.env.LLAMA_BASE && process.env.LLAMA_BASE.trim();
  const useLlmRouter = process.env.LLM_ROUTER_URL && process.env.LLM_ROUTER_URL.trim();
  
  if (!useExternalLlama && !useLlmRouter) {
    const llamaExe = findLlamaExe();
    const model = findModel();
    
    if (llamaExe && model) {
      registerProcess(supervisor, {
        name: 'llama-server',
        command: llamaExe,
        args: [
          '-m', model,
          '--ctx-size', String(process.env.CTX_SIZE || 8192),
          '--batch-size', String(process.env.BATCH_SIZE || 4096),
          '--host', '127.0.0.1',
          '--port', '8000',
          '--parallel', String(process.env.PARALLEL || 8),
          '--temp', '0.7'
        ],
        cwd: path.dirname(llamaExe),
        autoRestart: true,
        maxRestarts: 2
      });
    }
  }

  // Register TTS service if configured
  const ttsEnabled = process.env.TTS_ENABLED === 'true';
  if (ttsEnabled) {
    const piperExe = path.resolve(__dirname, '../../../piper/piper.exe');
    if (fs.existsSync(piperExe)) {
      registerProcess(supervisor, {
        name: 'tts-service',
        command: piperExe,
        args: [],
        cwd: path.dirname(piperExe),
        autoRestart: true
      });
    }
  }

  return supervisor;
}

// Helper functions from server.cjs
function findLlamaExe() {
  const BASE = path.resolve(__dirname, '../..');
  const LLAMA_DIR = path.join(BASE, 'llama.cpp');
  const guesses = [
    path.join(LLAMA_DIR, 'build', 'bin', 'Release', 'llama-server.exe'),
    path.join(LLAMA_DIR, 'build', 'bin', 'llama-server.exe')
  ];
  
  for (const g of guesses) {
    if (fs.existsSync(g)) return g;
  }
  
  return null;
}

function findModel() {
  const BASE = path.resolve(__dirname, '../..');
  const modelPath = process.env.DEFAULT_MODEL || process.env.LLAMA_MODEL;
  if (modelPath && fs.existsSync(modelPath)) {
    return modelPath;
  }
  
  const guesses = [
    path.join(BASE, 'Models', 'keykey', 'Llama-3.2-3B-Instruct-Q4_K_M.gguf'),
    path.join(BASE, 'Models', 'llama-3.2-3b-instruct-q4_k_m.gguf')
  ];
  
  for (const g of guesses) {
    if (fs.existsSync(g)) return g;
  }
  
  return null;
}

module.exports = {
  qflushAvailable,
  initQFlush,
  registerProcess,
  startProcess,
  stopProcess,
  getStatus,
  setupA11Supervisor
};
