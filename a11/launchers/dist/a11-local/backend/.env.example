# Environment variables for A11 Backend
PORT=3000
HOST_SERVER=0.0.0.0
LLM_ROUTER_URL=http://127.0.0.1:4545
LLAMA_PORT=8080
LLAMA_BASE=http://127.0.0.1:8080
LOCAL_LLM_URL=http://127.0.0.1:8080
TTS_BASE_URL=
TTS_PORT=5002
TTS_MODELS_DIR=
TTS_MODEL_PATH=/app/apps/tts/fr_FR-siwis-medium.onnx
PIPER_BIN=
ENABLE_PIPER_HTTP=false
