      return res.status(404).json({ error: 'gif_path_not_found' });
    }
    lastGifPath = gif_path;
    console.log('[A11][AVATAR] lastGifPath updated:', lastGifPath);
    return res.json({ ok: true });
  } catch (e) {
    console.error('[A11][AVATAR] update error:', e && e.message);
    return res.status(500).json({ error: String(e && e.message) });
  }
});

// Serve the current avatar GIF (proxy/stream). Frontend can always use /avatar.gif
app.get('/avatar.gif', (req, res) => {
  try {
    if (!lastGifPath || !fs.existsSync(lastGifPath)) {
      const idle = _find_idle_asset();
      if (idle) {
        console.warn('[A11][AVATAR] lastGifPath empty, serving idle asset:', idle);
        return res.sendFile(idle);
      }
      return res.status(404).send('no avatar available');
    }

    console.log('[A11][AVATAR] streaming avatar GIF:', lastGifPath);
    try {
      // Prefer redirecting the browser directly to the TTS /out/<file> URL when available.
      // This avoids proxy/streaming issues that can break GIF playback in some browsers.
      try {
        const basename = path.basename(lastGifPath);
        const ttsHost = (process.env.TTS_HOST && process.env.TTS_HOST.trim()) || 'http://127.0.0.1:5002';
        const redirectUrl = `${ttsHost.replace(/\/$/, '')}/out/${encodeURIComponent(basename)}`;
        console.log('[A11][AVATAR] redirecting avatar.gif to TTS server ->', redirectUrl);
        return res.redirect(307, redirectUrl);
      } catch (redirErr) {
        console.warn('[A11][AVATAR] redirect failed, falling back to streaming:', redirErr && redirErr.message);
      }

      const st = fs.statSync(lastGifPath);
      res.setHeader('Content-Type', 'image/gif');
      res.setHeader('Content-Length', String(st.size));
      res.setHeader('Accept-Ranges', 'bytes');
      res.setHeader('Cache-Control', 'no-cache, no-store, must-revalidate');
      res.setHeader('Pragma', 'no-cache');
      res.setHeader('Expires', '0');
      res.setHeader('Last-Modified', st.mtime.toUTCString());
      // Simple weak ETag using size+mtime
      res.setHeader('ETag', `W/"${st.size}-${st.mtimeMs}"`);

      const stream = fs.createReadStream(lastGifPath);
      stream.on('error', (err) => {
        console.error('[A11][AVATAR] error reading GIF:', err && err.message);
        const idle = _find_idle_asset();
        if (idle) return res.sendFile(idle);
        return res.status(500).send('avatar read error');
      });
      stream.pipe(res);
    } catch (e) {
      console.error('[A11][AVATAR] stat/read avatar error:', e && e.message);
      const idle = _find_idle_asset();
      if (idle) return res.sendFile(idle);
      return res.status(500).send('avatar read error');
    }
  } catch (e) {
    console.error('[A11][AVATAR] avatar.gif handler error:', e && e.message);
    res.status(500).send('avatar handler error');
  }
});
