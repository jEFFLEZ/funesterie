// Small net util
const net = require("node:net");
function isPortOpen(port) {
  return new Promise((resolve) => {
    const sock = new net.Socket();
    sock.once("error", () => resolve(false));
    sock.setTimeout(800, () => {
      sock.destroy();
      resolve(false);
    });
    sock.connect(port, "127.0.0.1", () => {
      sock.end();
      resolve(true);
    });
  });
}
