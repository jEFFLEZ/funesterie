# A11 Backend Configuration
# Copy this file to .env.local and adjust values as needed

# Server Configuration
PORT=3000
HOST_SERVER=127.0.0.1

# LLM Router (Cerbère)
LLM_ROUTER_URL=http://127.0.0.1:4545
LLM_ROUTER_PORT=4545

# Local LLM Backend
LLAMA_BASE=http://127.0.0.1:8000
LOCAL_LLM_URL=
LLAMA_PORT=8000
DEFAULT_MODEL=llama3.2:latest

# QFlush Process Management
MANAGE_CERBERE=true
MANAGE_TTS=false

# TTS Configuration (optional)
TTS_HOST=http://127.0.0.1:5002
TTS_BASE_URL=
TTS_PORT=5002
TTS_MODELS_DIR=
TTS_MODEL_PATH=apps/tts/fr_FR-siwis-medium.onnx
PIPER_BIN=
ENABLE_PIPER_HTTP=false
PIPER_START_CMD=
TTS_MAX_AGE_SEC=3600
TTS_CLEANUP_INTERVAL_SEC=600

# LLM Configuration
CTX_SIZE=8192
BATCH_SIZE=4096
PARALLEL=8

# Backend Mode
BACKEND=local

# Security (set to 'off' for local development)
NEZ_SECURITY_MODE=off

# CORS Origins (comma-separated)
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:5173,http://localhost:3000,https://funesterie.pro

# GPU Usage (optional)
USE_GPU=false
