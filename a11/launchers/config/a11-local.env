# A11 local launcher configuration
# Paths are resolved relative to the launchers folder.

A11_LOCAL_HOST=127.0.0.1
A11_UI_MODE=embedded
A11_AUTO_OPEN_UI=1
A11_DESKTOP_BROWSER=edge
A11_DESKTOP_WIDTH=1440
A11_DESKTOP_HEIGHT=960

A11_ENABLE_BACKEND=1
A11_ENABLE_TTS=1
A11_ENABLE_LLM=1
A11_ENABLE_QFLUSH=0

A11_BACKEND_PORT=3000
A11_TTS_PORT=5002
A11_LLM_PORT=8080
A11_QFLUSH_PORT=43421
A11_FRONTEND_PORT=5173

A11_PUBLIC_API_URL=https://api.funesterie.pro
A11_PUBLIC_FRONTEND_URL=https://a11.funesterie.pro

A11_BACKEND_DIR=..\a11backendrailway\apps\server
A11_TTS_DIR=..\a11backendrailway\apps\tts
A11_FRONTEND_DIR=..\a11frontendnetlify\apps\web
A11_WEB_DIST_DIR=..\a11frontendnetlify\apps\web\dist
A11_QFLUSH_DIR=..\a11qflushrailway
A11_LLM_EXE=..\a11llm\llm\server\llama-server.exe
A11_LLM_MODEL=..\a11llm\llm\models\Llama-3.2-3B-Instruct-Q4_K_M.gguf
A11_TTS_MODEL=..\a11backendrailway\apps\tts\fr_FR-siwis-medium.onnx
A11_TTS_PIPER=..\a11backendrailway\apps\tts\piper.exe
A11_TTS_ESPEAK=..\a11backendrailway\apps\tts\espeak-ng-data

A11_QFLUSH_CHAT_FLOW=a11.chat.v1
A11_QFLUSH_MEMORY_SUMMARY_FLOW=a11.memory.summary.v1

A11_PACKAGE_ROOT=dist\a11-local
